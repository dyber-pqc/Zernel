# Zernel Kernel Configuration — x86_64
# Copyright (C) 2026 Dyber, Inc.
# Based on Linux 6.12+ with ML-specific optimizations
#
# This is a partial .config showing Zernel-specific settings.
# The full config is generated by merging this with defconfig.

# === sched_ext Framework ===
CONFIG_SCHED_CLASS_EXT=y
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y

# === Memory Management ===
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_HUGETLBFS=y

# === Timer ===
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_HIGH_RES_TIMERS=y

# === NUMA ===
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y
CONFIG_NUMA_BALANCING_DEFAULT_ENABLED=y
CONFIG_MEMPOLICY=y

# === RDMA / InfiniBand ===
CONFIG_INFINIBAND=y
CONFIG_INFINIBAND_USER_ACCESS=y
CONFIG_RDMA_RXE=y

# === I/O ===
CONFIG_IO_URING=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y

# === Network ===
CONFIG_TCP_CONG_BBR=y

# === GPU Support ===
CONFIG_DRM=y
CONFIG_DRM_NOUVEAU=n
# NVIDIA open modules loaded separately

# === Containers ===
CONFIG_NAMESPACES=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_MEMORY=y
CONFIG_CGROUP_NET_CLASSID=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_CGROUP_PIDS=y
CONFIG_OVERLAY_FS=y
